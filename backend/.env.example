PORT=5000
MONGODB_URI=mongodb://localhost:27017/taskflow-ai
JWT_SECRET=super_secret_jwt_token_flow_key_123!
NODE_ENV=development

# Email Verification (Nodemailer config - standard SMTP)
# Leave empty or use local mock by default
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@taskflowai.com

# OpenAI API Key (leave empty to run local mock/heuristics fallback)
OPENAI_API_KEY=
